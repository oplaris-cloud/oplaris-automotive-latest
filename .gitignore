# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
import-report.json
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (.env.local, .env.production etc. stay private)
.env*
# .env.example is the documented template — always committed.
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code per-worktree scratch (state lives in repo root via the
# tracked .claude/settings*.json — worktrees themselves shouldn't sync).
.claude/worktrees/

# Envato asset packs — ~20 MB each, downloaded externally per illustration
# import, do NOT commit. Naming convention is `<slug>-YYYY-MM-DD-…-utc`.
/public/*-utc/
/public/*-utc-*/
