# Mirrors .gitignore + excludes anything that should never land in the
# production image. Keeps the build context small (faster uploads to the
# BuildKit builder) and guarantees no secret/dev-only cruft sneaks in.

# dependencies — reinstalled fresh by the `deps` stage
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-store

# Next.js output — regenerated by the `builder` stage
.next
out
build
import-report.json

# env files — runtime secrets injected by Dokploy, never baked into the image
.env
.env.*
!.env.example

# version control
.git
.gitignore
.gitattributes

# IDE + OS
.vscode
.idea
.DS_Store
Thumbs.db
*.swp

# tests + fixtures (image runs no tests)
tests
playwright-report
playwright
coverage
*.tsbuildinfo

# docs — build context only needs code + package files
docs
*.md
!README.md
AGENTS.md
CLAUDE.md
STANDUP*.md
Dudley_Project_Plan.docx
dudley-requirements-v1.md

# CI + infra meta — not runtime concerns
.github
.husky
.claude
.mcp.json
skill-updates

# misc dev cruft
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.pem

# Preview HTML files committed to repo root
oplaris-*.html

# Supabase CLI scratch
supabase/.branches
supabase/.temp

# Dockerfile context — don't recurse
Dockerfile
.dockerignore
compose.yml
