# =============================================================================
# Oplaris Automotive — environment variables
# =============================================================================
# Copy to .env.local for development. NEVER commit .env or .env.local.
# Production secrets are injected by Dokploy.
#
# Variables prefixed with NEXT_PUBLIC_ are inlined into the client bundle.
# DO NOT put anything secret behind that prefix. Audited on every PR.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Used to build canonical URLs in emails / SMS / signed tokens. No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public-facing customer status page (separate origin so cookies are scoped).
NEXT_PUBLIC_STATUS_URL=http://localhost:3000/status

# Node environment — set automatically by Next.js. Do not set manually.
# NODE_ENV=development

# -----------------------------------------------------------------------------
# Supabase (managed — supabase.com)
# -----------------------------------------------------------------------------
# Project URL and anon (public) key — safe to ship to the client.
# From Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me-public-anon-key

# Service-role key — SERVER ONLY. Never NEXT_PUBLIC_*.
# Bypasses RLS. Used only by Route Handlers and admin scripts.
SUPABASE_SERVICE_ROLE_KEY=replace-me-server-only-service-role-key

# JWT secret — used by Supabase Auth for signing user JWTs.
# From dashboard → Project Settings → API → JWT Settings.
SUPABASE_JWT_SECRET=replace-me-server-only-jwt-secret

# -----------------------------------------------------------------------------
# Twilio (Dudley's existing account)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace-me-server-only-auth-token
TWILIO_FROM_NUMBER=+441234567890

# Twilio webhook secret — verify X-Twilio-Signature on inbound callbacks.
# Set to the auth token of the messaging service used to send the SMS.
TWILIO_WEBHOOK_BASE_URL=https://app.example.invalid

# -----------------------------------------------------------------------------
# DVSA Trade API — OAuth2 client_credentials + API key
# -----------------------------------------------------------------------------
# Used for both vehicle reg lookup and MOT history. Server-only.
# OAuth2 token is fetched from Azure AD using tenant + client credentials.
DVSA_CLIENT_ID=replace-me
DVSA_CLIENT_SECRET=replace-me-server-only
DVSA_TENANT_ID=replace-me-azure-tenant-id
DVSA_SCOPE=https://tapi.dvsa.gov.uk/.default
DVSA_API_KEY=replace-me-x-api-key
DVSA_BASE_URL=https://tapi.dvsa.gov.uk/
DVSA_HISTORY_BASE_URL=https://history.mot.api.gov.uk/

# -----------------------------------------------------------------------------
# Cryptographic secrets (server-only)
# -----------------------------------------------------------------------------
# HMAC key for signing customer approval tokens (Phase 7).
# Generate with: openssl rand -base64 64
APPROVAL_HMAC_SECRET=replace-me-server-only-base64-64-bytes

# Pepper for hashing phone numbers in private.status_codes (Phase 9).
# Generate with: openssl rand -base64 64
STATUS_PHONE_PEPPER=replace-me-server-only-base64-64-bytes

# Server Actions encryption key — keeps closed-over variables consistent
# across multi-instance deploys. Generate with: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=replace-me-server-only-base64-32-bytes

# Kiosk pairing secret — used by managers to issue per-device kiosk cookies (Phase 10).
# Generate with: openssl rand -base64 64
KIOSK_PAIRING_SECRET=replace-me-server-only-base64-64-bytes

# -----------------------------------------------------------------------------
# hCaptcha (public booking form anti-abuse — not the kiosk)
# -----------------------------------------------------------------------------
# Site key is shipped to the client; secret is server-only.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# Status page dev bypass (dev/staging ONLY)
# -----------------------------------------------------------------------------
# When `true` the /api/status/request-code route returns the 6-digit
# verification code inline in the JSON response (behind a yellow banner)
# instead of dispatching via Twilio. Use for staging E2E when the Twilio
# account is unavailable.
#
# FORBIDDEN IN PRODUCTION — `serverEnv()` throws at boot if this is `true`
# and NODE_ENV === "production". A CI check at deploy time is the second
# line of defence (see docs/redesign/STAGING_SMS_BYPASS.md).
STATUS_DEV_BYPASS_SMS=false

# -----------------------------------------------------------------------------
# Dev-only tooling (not read by the app, not set in production)
# -----------------------------------------------------------------------------
# Override the default local Postgres URL used by `pnpm db:seed-dev`.
# Falls back to the local Supabase CLI default if unset:
# postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Consumed by `scripts/seed-dev-users.ts`.
SUPABASE_DB_URL=

# -----------------------------------------------------------------------------
# Backups (Phase 4 — scripts/backup.sh + scripts/restore.sh)
# -----------------------------------------------------------------------------
# All three groups below are consumed by Dokploy's scheduled-task
# sidecar, NOT by the app container. The app image does not ship with
# pg_dump / age / rclone — those live in a dedicated backup container.
#
# Never set BACKUP_AGE_IDENTITY_FILE or TARGET_DATABASE_URL in the
# app's Dokploy env — they exist only in the restore runbook (Rule
# #12 gate), which is a manually-invoked operator workflow.

# --- nightly backup (scripts/backup.sh) ---
# rclone remote spec — e.g. `b2:oplaris-backups` or `s3:oplaris`. The
# script writes under `${remote}/oplaris/YYYY/MM/`.
BACKUP_RCLONE_REMOTE=

# age public key (ssh-age or age format). The matching identity
# (private key) lives OFFLINE — USB, 1Password, hardware token.
BACKUP_AGE_PUBLIC_KEY=

# Postgres connection string consumed by `pg_dump`. Prefer a
# read-replica if one exists to avoid load on the primary.
# e.g. postgres://backup@replica.internal:5432/oplaris
DATABASE_URL=

# --- restore driver (scripts/restore.sh — Rule #12 gate) ---
# Filesystem path to the age PRIVATE key. MUST be mounted at runtime
# (e.g. Docker volume from a USB dev), never committed, never in
# Dokploy's persistent env. Only populated during the operator's
# manual restore exercise.
BACKUP_AGE_IDENTITY_FILE=

# Scratch-DB connection string. `scripts/restore.sh` refuses to run
# if this contains the strings 'prod' or 'production'.
TARGET_DATABASE_URL=

# Optional — override "pull latest *.age from the remote" with an
# explicit file name. Use for point-in-time restores during incident
# response.
BACKUP_FILE=
